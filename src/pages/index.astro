---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostList from '@/components/PostList.astro';
import { photos } from '@/data/photos';
import { isPublished, sortPosts } from '@/utils/posts';

const posts = sortPosts((await getCollection('posts')).filter(isPublished));
const latestPosts = posts.slice(0, 6);
const featuredPhoto = photos[0];
---

<BaseLayout>
  <section class="page-heading page-heading--home">
    <h1>首页</h1>
  </section>

  <PostList posts={latestPosts} />

  <section class="home-photo" aria-labelledby="home-photo-title">
    <h2 id="home-photo-title">
      <a href="/photography/">摄影</a>
    </h2>
    <a class="home-photo__image" href="/photography/" aria-label="查看摄影">
      <img
        src={featuredPhoto.src}
        alt={featuredPhoto.alt}
        width={featuredPhoto.width}
        height={featuredPhoto.height}
        loading="lazy"
        decoding="async"
      />
    </a>
    <p>{featuredPhoto.description}</p>
    <a class="read-more" href="/photography/">View Photography</a>
  </section>
</BaseLayout>

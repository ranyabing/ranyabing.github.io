---
import { SITE } from '@/data/site';

const nav = [
  { href: '/', label: '首页' },
  { href: '/posts/', label: '文章' },
  { href: '/photography/', label: '摄影' },
  { href: '/about/', label: '关于' }
];

const pathname = Astro.url.pathname;

function isActive(href: string) {
  return href === '/' ? pathname === href : pathname.startsWith(href);
}
---

<header class="site-header">
  <a class="brand" href="/" aria-label={SITE.title}>
    <span>{SITE.title}</span>
  </a>
  <div class="header-actions">
    <nav aria-label="主导航">
      {
        nav.map((item) => (
          <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
            {item.label}
          </a>
        ))
      }
    </nav>
    <button class="theme-toggle" type="button" data-theme-toggle aria-label="切换深色模式" title="切换深色模式">
      <span class="theme-toggle__icon" aria-hidden="true"></span>
      <span class="sr-only">切换深色模式</span>
    </button>
  </div>
</header>

<script is:inline>
  (() => {
    const root = document.documentElement;
    const button = document.querySelector('[data-theme-toggle]');

    if (!button) {
      return;
    }

    const setTheme = (theme) => {
      root.dataset.theme = theme;
      try {
        localStorage.setItem('theme', theme);
      } catch {
        /* Ignore storage errors. */
      }

      const nextLabel = theme === 'dark' ? '切换浅色模式' : '切换深色模式';
      button.setAttribute('aria-label', nextLabel);
      button.setAttribute('title', nextLabel);
    };

    const initialTheme = root.dataset.theme === 'dark' ? 'dark' : 'light';
    setTheme(initialTheme);

    button.addEventListener('click', () => {
      setTheme(root.dataset.theme === 'dark' ? 'light' : 'dark');
    });
  })();
</script>

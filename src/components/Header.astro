---
import { SITE } from '@/data/site';

const nav = [
  { href: '/', label: '首页' },
  { href: '/posts/', label: '文章' },
  { href: '/tags/', label: '标签' },
  { href: '/about/', label: '关于' }
];
---

<header class="site-header">
  <a class="brand" href="/" aria-label={SITE.title}>
    <img src={SITE.avatar} alt="" width="40" height="40" loading="eager" />
    <span>{SITE.title}</span>
  </a>
  <nav aria-label="主导航">
    {
      nav.map((item) => (
        <a href={item.href} aria-current={Astro.url.pathname === item.href ? 'page' : undefined}>
          {item.label}
        </a>
      ))
    }
    <a href="/rss.xml">RSS</a>
  </nav>
</header>
